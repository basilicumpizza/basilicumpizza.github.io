<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="content-type">
    <title>Basilicum</title>
    <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: ffffff;
    }

    header {
      background-color: #284338;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .container {
      padding: 20px;
    }

    .produtos {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .produto {
      background: white;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      overflow: hidden;
      transition: transform 0.2s;
    }

    .produto:hover {
      transform: scale(1.03);
    }

    .produto img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }

    .produto-info {
      padding: 15px;
    }

    .produto-info h3 {
      margin: 0 0 10px;
    }

    .produto-info p {
      font-size: 14px;
      color: #555;
    }

    .preco {
      color: #284338;
      font-weight: bold;
      margin-top: 10px;
    }

    footer {
      text-align: center;
      padding: 15px;
      background: #ddd;
      margin-top: 20px;
         }
              
    </style>
  </head>
